# ~/.zshenv - Sourced by ALL zsh shells (interactive and non-interactive)
# Keep this minimal - only env vars needed by scripts/tools

# Helpers
has() { command -v "$1" > /dev/null 2>&1; }

# -------------------------------------------
# Homebrew env (inlined equivalent of `brew shellenv`, no subshell fork)
# -------------------------------------------
for _hb in /opt/homebrew /usr/local /home/linuxbrew/.linuxbrew; do
  if [[ -d "$_hb/bin" ]]; then
    export HOMEBREW_PREFIX="$_hb"
    export HOMEBREW_CELLAR="$_hb/Cellar"
    export HOMEBREW_REPOSITORY="$_hb"
    fpath=("$_hb/share/zsh/site-functions" $fpath)
    export PATH="$_hb/bin:$_hb/sbin:$PATH"
    export INFOPATH="$_hb/share/info${INFOPATH:+:$INFOPATH}"
    break
  fi
done
unset _hb

# -------------------------------------------
# Path
# -------------------------------------------
export PATH="$HOME/.local/bin:$PATH"

# -------------------------------------------
# mise (version manager) — activate output is cached, regenerated when
# the mise binary is newer than the cache file. Saves ~10ms per shell.
# -------------------------------------------
if has mise; then
  _mise_cache="$HOME/.cache/zsh/mise-activate.zsh"
  [[ -d "${_mise_cache:h}" ]] || mkdir -p "${_mise_cache:h}"
  if [[ ! -s "$_mise_cache" || "$_mise_cache" -ot "$(command -v mise)" ]]; then
    mise activate zsh > "$_mise_cache" 2>/dev/null
  fi
  source "$_mise_cache"
  unset _mise_cache
fi

# -------------------------------------------
# Editor
# -------------------------------------------
export EDITOR="zed"

# -------------------------------------------
# Linear CLI
# -------------------------------------------
export LINEAR_ISSUE_SORT="manual"

{{ if lookPath "op" }}
# API Keys (from 1Password)
export LINEAR_API_KEY="{{ onepasswordRead "op://Private/Linear API Key/credential" "my.1password.com" }}"
export TAVILY_API_KEY="{{ onepasswordRead "op://Private/Tavily API Key/credential" "my.1password.com" }}"
export JINA_API_KEY="{{ onepasswordRead "op://Private/Jina API Key/credential" "my.1password.com" }}"
export CONTEXT7_API_KEY="{{ onepasswordRead "op://Private/Context7 API Key/credential" "my.1password.com" }}"
{{- end }}
