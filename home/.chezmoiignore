# smithers runtime state (mirror of dot_smithers/.gitignore): chezmoi manages
# only source files (workflows/lib/bin/package.json/bun.lock/patches); deps
# land via the run_onchange bun-install script, run state stays unmanaged.
# Without these entries a dev checkout used as --source (make test-local)
# would try to manage node_modules and the runs database.
.claude/.smithers/node_modules
.claude/.smithers/node_modules/**
.claude/.smithers/smithers.db*
.claude/.smithers/.smithers
.claude/.smithers/.smithers/**
.claude/.smithers/executions
.claude/.smithers/executions/**
.claude/.smithers/runs
.claude/.smithers/runs/**
.claude/.smithers/sandboxes
.claude/.smithers/sandboxes/**
.claude/.smithers/state
.claude/.smithers/state/**
.claude/.smithers/tmp
.claude/.smithers/tmp/**
.claude/.smithers/dist
.claude/.smithers/dist/**
.claude/.smithers/workflows/run-*.log
.claude/.smithers/workflows/.worktrees
.claude/.smithers/workflows/.worktrees/**

# Linux-only files (ignore on macOS)
{{ if ne .chezmoi.os "linux" }}
.chezmoiscripts/linux
{{ end }}
