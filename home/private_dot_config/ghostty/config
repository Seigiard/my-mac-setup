font-family = Iosevka Nerd Font
#font-family = JetBrains Mono
#font-family = Rec Mono Duotone
font-size = 18
#theme = Gruvbox Dark
#theme = Xcode Light hc
#theme = Pro Light
theme = Flexoki Light
cursor-style = block

shell-integration = zsh
shell-integration-features = no-cursor,sudo,title

unfocused-split-opacity = 0.7

window-inherit-working-directory = true

mouse-hide-while-typing = true
mouse-scroll-multiplier = 0.5
#mouse-scroll-multiplier = 2

macos-option-as-alt = right

quit-after-last-window-closed=true
window-save-state = always
macos-titlebar-style = tabs
window-colorspace = "display-p3"
window-new-tab-position = "end"
window-padding-balance = true
window-padding-x = 0
window-padding-y = 0

clipboard-trim-trailing-spaces = true
copy-on-select = clipboard

font-feature = -calt
font-feature = -liga
font-feature = -dlig

#term = xterm-256color
term = xterm-ghostty

# BEGIN auto-launch herdr
# Launch Herdr by default when available. Do not exec it: Herdr detach should
# return to a plain Ghostty login shell while keeping the Herdr server/session alive.
command = shell:/bin/zsh -lc 'export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"; if command -v herdr >/dev/null 2>&1; then herdr; fi; exec "${SHELL:-/bin/zsh}" -l'
# END auto-launch herdr

# KEYBINDINGS
keybind = shift+enter=text:\x1b[13;2u
keybind = ctrl+key_c=text:\x03


# BEGIN macOS-style herdr shortcuts test
# Sends macOS-style shortcuts to Herdr. Most map to ctrl+b prefix sequences;
# pane focus/swap use direct Herdr key bindings configured in Herdr config.
keybind = cmd+KeyT=text:\x02c # palette: Tabs & workspaces | ⌘T | New tab
keybind = cmd+t=unbind
keybind = cmd+KeyN=text:\x02N # palette: Tabs & workspaces | ⌘N | New workspace
keybind = cmd+n=unbind
keybind = cmd+KeyD=text:\x02v # palette: Panes | ⌘D | Split right
keybind = cmd+d=unbind
keybind = cmd+shift+KeyD=text:\x02- # palette: Panes | ⌘⇧D | Split down
keybind = cmd+shift+d=unbind
keybind = cmd+shift+enter=text:\x02z # palette: Panes | ⌘⇧Enter | Zoom pane
keybind = shift+alt+left=text:\x1b[1;4D # palette: Panes | ⇧⌥←↓↑→ | Focus pane
keybind = shift+alt+down=text:\x1b[1;4B
keybind = shift+alt+up=text:\x1b[1;4A
keybind = shift+alt+right=text:\x1b[1;4C
keybind = shift+alt+KeyH=text:\x1b[1;4D # palette: Panes | ⇧⌥H/J/K/L | Focus pane
keybind = shift+alt+KeyJ=text:\x1b[1;4B
keybind = shift+alt+KeyK=text:\x1b[1;4A
keybind = shift+alt+KeyL=text:\x1b[1;4C
keybind = ctrl+shift+left=text:\x1b[1;6D # palette: Panes | ⌃⇧←↓↑→ | Move pane
keybind = ctrl+shift+down=text:\x1b[1;6B
keybind = ctrl+shift+up=text:\x1b[1;6A
keybind = ctrl+shift+right=text:\x1b[1;6C
keybind = ctrl+shift+KeyH=text:\x1b[1;6D # palette: Panes | ⌃⇧H/J/K/L | Move pane
keybind = ctrl+shift+KeyJ=text:\x1b[1;6B
keybind = ctrl+shift+KeyK=text:\x1b[1;6A
keybind = ctrl+shift+KeyL=text:\x1b[1;6C
keybind = cmd+KeyW=text:\x02x # palette: Panes | ⌘W | Close pane/tab
keybind = cmd+w=unbind
keybind = cmd+shift+KeyW=text:\x02D # palette: Tabs & workspaces | ⌘⇧W | Close workspace
keybind = cmd+shift+w=unbind
keybind = cmd+KeyK=text:\x02W
keybind = cmd+k=unbind
keybind = cmd+KeyL=text:\x02T
keybind = cmd+l=unbind
keybind = cmd+shift+KeyP=text:\x02\x20
keybind = cmd+shift+p=unbind
keybind = cmd+shift+KeyE=text:\x02q
keybind = cmd+shift+e=unbind
keybind = alt+t=text:\x02c

# Browser-style tab cycling via Herdr defaults: prefix+n / prefix+p.
keybind = ctrl+tab=text:\x02n # palette: Tabs & workspaces | ⌃Tab | Next tab
keybind = cmd+shift+left_bracket=text:\x02p # palette: Tabs & workspaces | ⌘⇧[ / ] | Prev/next tab
keybind = cmd+shift+right_bracket=text:\x02n

# Workspace switching via Herdr defaults/custom prefix bindings.
keybind = ctrl+shift+tab=text:\x02w # palette: Tabs & workspaces | ⌃⇧Tab | Workspace picker
keybind = ctrl+shift+left_bracket=text:\x02{ # palette: Tabs & workspaces | ⌃⇧[ / ] | Prev/next workspace
keybind = ctrl+shift+right_bracket=text:\x02}

# Cmd+1..9 switches herdr tabs via herdr default prefix+1..9.
keybind = cmd+digit_1=text:\x021 # palette: Tabs & workspaces | ⌘1…9 | Switch tab
keybind = cmd+1=text:\x021
keybind = cmd+digit_2=text:\x022
keybind = cmd+2=text:\x022
keybind = cmd+digit_3=text:\x023
keybind = cmd+3=text:\x023
keybind = cmd+digit_4=text:\x024
keybind = cmd+4=text:\x024
keybind = cmd+digit_5=text:\x025
keybind = cmd+5=text:\x025
keybind = cmd+digit_6=text:\x026
keybind = cmd+6=text:\x026
keybind = cmd+digit_7=text:\x027
keybind = cmd+7=text:\x027
keybind = cmd+digit_8=text:\x028
keybind = cmd+8=text:\x028
keybind = cmd+digit_9=text:\x029
keybind = cmd+9=text:\x029

# Ctrl+Shift+1..9 sends enhanced key sequences for direct herdr workspace jumps.
keybind = ctrl+shift+digit_1=text:\x1b[49;6u # palette: Tabs & workspaces | ⌃⇧1…9 | Switch workspace
keybind = ctrl+shift+1=text:\x1b[49;6u
keybind = ctrl+shift+digit_2=text:\x1b[50;6u
keybind = ctrl+shift+2=text:\x1b[50;6u
keybind = ctrl+shift+digit_3=text:\x1b[51;6u
keybind = ctrl+shift+3=text:\x1b[51;6u
keybind = ctrl+shift+digit_4=text:\x1b[52;6u
keybind = ctrl+shift+4=text:\x1b[52;6u
keybind = ctrl+shift+digit_5=text:\x1b[53;6u
keybind = ctrl+shift+5=text:\x1b[53;6u
keybind = ctrl+shift+digit_6=text:\x1b[54;6u
keybind = ctrl+shift+6=text:\x1b[54;6u
keybind = ctrl+shift+digit_7=text:\x1b[55;6u
keybind = ctrl+shift+7=text:\x1b[55;6u
keybind = ctrl+shift+digit_8=text:\x1b[56;6u
keybind = ctrl+shift+8=text:\x1b[56;6u
keybind = ctrl+shift+digit_9=text:\x1b[57;6u
keybind = ctrl+shift+9=text:\x1b[57;6u
# END macOS-style herdr shortcuts test
