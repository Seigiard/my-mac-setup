[
  // Custom bindings
  {
    "use_key_equivalents": true,
    "bindings": {
      "cmd-shift-c": null,
      "cmd-`": null,
      "cmd-~": null,
      "cmd-1": "project_panel::ToggleFocus",
      "cmd-2": "outline_panel::ToggleFocus",
      "cmd-3": "git_panel::ToggleFocus",
      "cmd-i": "workspace::ToggleRightDock",
      "cmd-e": "workspace::FocusCenterPane",
      "cmd-j": "terminal_panel::Toggle",
      "cmd-shift-j": "workspace::NewTerminal",
      "cmd-f": "search::FocusSearch",
      "cmd-r": "search::ToggleReplace",
      "cmd-alt-1": "pane::RevealInProjectPanel",
      "cmd-shift-enter": "workspace::ToggleZoom",
      "ctrl-r": ["projects::OpenRecent", { "create_new_window": false }],
    },
  },
  {
    "context": "Editor && mode == full",
    "use_key_equivalents": true,
    "bindings": {
      "cmd-d": "pane::SplitRight",
      "cmd-shift-d": "pane::SplitDown",
      "cmd-e": "workspace::FocusCenterPane",
      "cmd-j": "terminal_panel::Toggle",
      "cmd-shift-j": "workspace::NewTerminal",
      "cmd-k": "assistant::InlineAssist",
    },
  },
  {
    "context": "Editor && multibuffer",
    "use_key_equivalents": true,
    "bindings": {
      "cmd-alt-o": "editor::OpenExcerpts",
    },
  },
  {
    "context": "InlineAssistEditor",
    "bindings": {
      "cmd-k": "editor::Cancel",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-d": "pane::SplitRight",
      "cmd-shift-d": "pane::SplitDown",
      "cmd-e": "editor::ToggleFocus",
      "cmd-j": "terminal_panel::Toggle",
      "cmd-shift-j": "workspace::NewTerminal",
      "alt-b": null,
      "shift-enter": ["terminal::SendText", "\u001b[13;2u"],
      "cmd-enter": ["terminal::SendText", "\u001b[13;2u"],
    },
  },
]
