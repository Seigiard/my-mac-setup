{
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
  },
  "terminal": {
    "dock": "bottom",
    "default_width": 600,
    "font_family": "Iosevka Nerd Font Mono",
    "default_height": 500,
    "copy_on_select": true,
    "font_size": 18,
  },
  "when_closing_with_no_tabs": "keep_window_open",
  "ui_font_size": 19,
  "buffer_font_family": "Iosevka Nerd Font Mono",
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "use_modifier_to_send": false,
    "default_model": {
      "model": "claude-sonnet-4",
      "provider": "zed.dev",
    },
    "inline_assistant_model": {
      "model": "claude-sonnet-4-6",
      "provider": "zed.dev",
    },
    "commit_message_model": {
      "model": "claude-haiku-4-5",
      "provider": "zed.dev",
    },
    "default_profile": "ask",
    "default_width": 600,
  },
  "project_panel": {
    "default_width": 350,
  },
  "git_panel": {
    "tree_view": true,
    "default_width": 350,
  },
  "debugger": {
    "button": true,
  },
  "search": {
    "button": true,
  },
  "buffer_font_size": 19,
  "wrap_guides": [120],
  "theme": "Flexoki Light",
  "title_bar": {
    "show_project_items": true,
    "show_menus": false,
    "show_branch_icon": false,
  },
  "preferred_line_length": 120,
  "outline_panel": {
    "default_width": 350,
  },
  "status_bar": {
    "active_language_button": true,
    "cursor_position_button": false,
  },
  "format_on_save": "on",
  "base_keymap": "JetBrains",
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
  "tab_size": 2,
  "agent_buffer_font_size": 16,
  "code_actions_on_format": {
    "source.fixAll.eslint": true,
  },
  "notification_panel": {
    "button": false,
    "dock": "left",
  },
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
    "enabled_in_text_threads": false,
  },
  "soft_wrap": "preferred_line_length",
  "tab_bar": {
    "show_nav_history_buttons": false,
  },
  "collaboration_panel": {
    "button": false,
    "dock": "left",
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
  },
  "buffer_font_weight": 400,
  "ui_font_family": ".ZedSans",
  "journal": {
    "path": "~/Dropbox/Knowledge Base",
    "hour_format": "hour24",
  },
  "diagnostics": {
    "button": true,
  },
}
