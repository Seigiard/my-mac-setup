{
  "cli_default_open_behavior": "existing_window",
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "pi-acp": {
      "type": "registry"
    },
    "opencode": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "lsp": {},
  "tabs": {
    "git_status": true,
    "file_icons": true
  },
  "terminal": {
    "bell": "system",
    "dock": "bottom",
    "default_width": 600,
    "font_family": "IosevkaTerm Nerd Font Mono",
    "default_height": 500,
    "copy_on_select": true,
    "option_as_meta": false,
    "font_size": 18
  },
  "when_closing_with_no_tabs": "keep_window_open",
  "ui_font_size": 19,
  "buffer_font_family": "IosevkaTerm Nerd Font Mono",
  "agent": {
    "play_sound_when_agent_done": "always",
    "notify_when_agent_waiting": "all_screens",
    "sidebar_side": "right",
    "dock": "right",
    "tool_permissions": {
      "default": "allow"
    },
    "use_modifier_to_send": false,
    "default_model": {
      "model": "claude-sonnet-4",
      "provider": "zed.dev"
    },
    "inline_assistant_model": {
      "model": "claude-sonnet-4-6",
      "provider": "zed.dev"
    },
    "commit_message_model": {
      "model": "claude-haiku-4-5",
      "provider": "zed.dev"
    },
    "default_profile": "ask",
    "default_width": 600
  },
  "project_panel": {
    "git_status_indicator": true,
    "dock": "left",
    "default_width": 350
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true,
    "default_width": 350
  },
  "debugger": {
    "button": true
  },
  "search": {
    "button": true
  },
  "buffer_font_size": 19,
  "wrap_guides": [120],
  "theme": "Flexoki Light",
  "title_bar": {
    "show_project_items": true,
    "show_menus": false
  },
  "preferred_line_length": 120,
  "outline_panel": {
    "dock": "left",
    "default_width": 350
  },
  "status_bar": {
    "active_language_button": true,
    "cursor_position_button": false
  },
  "format_on_save": "on",
  "base_keymap": "JetBrains",
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },
  "tab_size": 2,
  "agent_buffer_font_size": 16,
  "code_actions_on_format": {
    "source.fixAll.eslint": true
  },
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle"
  },
  "soft_wrap": "prefer_line",
  "tab_bar": {
    "show_nav_history_buttons": false
  },
  "collaboration_panel": {
    "button": false,
    "dock": "left"
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false
  },
  "buffer_font_weight": 400,
  "ui_font_family": ".ZedSans",
  "journal": {
    "path": "~/Dropbox/Knowledge Base",
    "hour_format": "hour24"
  },
  "diagnostics": {
    "button": true
  }
}
