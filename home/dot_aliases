# -------------------------------------------
# Network (OS-specific)
# -------------------------------------------

if [[ "$OS" == "macos" ]]; then
  alias ports='lsof -iTCP -sTCP:LISTEN -n -P'
  alias localip='ipconfig getifaddr en0'
