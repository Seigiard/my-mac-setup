alias gpl='git pull'
alias gl='git log --oneline -10'
alias gd='git diff'
alias gco='git checkout'
alias gb='git branch'
alias lg='lazygit'

check-deps() (
  cd "$(git rev-parse --show-toplevel)" || return 1
  if git rev-parse -q --verify ORIG_HEAD >/dev/null \
     && ! git diff --quiet ORIG_HEAD HEAD -- bun.lock; then
    echo "bun.lock changed — bun install"
    bun install || return 1
  fi
  bun run build:all -- --env-mode=loose
)

gpmain() {
  git pullmain "$@"
}

gmmain() {
  local merge_status

  echo '→ Updating main...'
  gpmain || return $?

  echo '→ Merging main into current branch...'
  git merge main --no-edit
  merge_status=$?

  if [[ -n "$(git ls-files --unmerged)" ]]; then
    echo '✗ Conflicts detected, launching Pi...'
    pi --print 'fix all merge conflicts'
    return $?
  fi

  if [[ $merge_status -ne 0 ]]; then
    echo '✗ Merge failed'
    return $merge_status
  fi

  echo '✓ Merged cleanly'
}

