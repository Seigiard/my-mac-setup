if [[ "$OS" == "macos" ]]; then
  alias o='open .'
  alias ql='qlmanage -p'
  alias flushdns='sudo dscacheutil -flushcache; sudo killall -HUP mDNSResponder'

  # SMB mounts (home.local) - uses Finder for native credential handling
