# -------------------------------------------
# Claude Code + Tmux
# -------------------------------------------

tm() {
  local session_name
  session_name=$(basename "$PWD" | tr '.' '_')
  printf '\033]0;💻 %s\007' "$session_name"
  if tmux has-session -t "$session_name" 2>/dev/null; then
    tmux attach-session -t "$session_name"
  else
    tmux new-session -s "$session_name"
  fi
}

# Tmux picker: fzf to choose session, or arg, or fall back to tm (current dir)
tp() {
  if ! has tmux; then
    echo "tmux is not installed"
    return 1
  fi

  if [[ $(tmux list-sessions 2>/dev/null | wc -l) -eq 0 ]]; then
    tm
    return
  fi

  if [[ $# -eq 0 ]]; then
    local selected_session
    selected_session=$(tmux list-sessions -F "#{session_attached} #{session_name}#{?session_attached, (attached),}" \
      | sort -rn \
      | sed -E 's/^[0-9]+ //' \
      | fzf --height 40% --reverse \
      | sed -E 's/ \(attached\)$//')

    if [[ -n "$selected_session" ]]; then
      printf '\033]0;💻 %s\007' "$selected_session"
      tmux attach-session -t "$selected_session"
    else
      tm
    fi
  else
    local session_name="$1"
    printf '\033]0;💻 %s\007' "$session_name"
    if tmux has-session -t "$session_name" 2>/dev/null; then
      tmux attach-session -t "$session_name"
    else
      tmux new-session -s "$session_name"
    fi
  fi
}

# -------------------------------------------
# Misc
# -------------------------------------------

alias reload='source ~/.zshrc'
alias path='echo -e ${PATH//:/\\n}'
alias now='date +"%Y-%m-%d %H:%M:%S"'
alias week='date +%V'
alias zsh-bench='for i in {1..5}; do time zsh -i -c exit; done'

# Alert for long-running commands (Linux only)
if [[ "$OS" == "linux" ]]; then
  alias alert='notify-send --urgency=low -i "$([ $? = 0 ] && echo terminal || echo error)" "$(history|tail -n1|sed -e '\''s/^\s*[0-9]\+\s*//;s/[;&|]\s*alert$//'\'')"'
fi

# -------------------------------------------
# Yazi - cd to directory on exit
# -------------------------------------------

function y() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}
