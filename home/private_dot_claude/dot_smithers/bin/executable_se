#!/usr/bin/env bash
# se — CLI wrapper over smithers for the se-pipeline workflow.
# Launch/observe durable pipeline runs without bunx incantations.
set -euo pipefail

SMITHERS_DIR="${SE_SMITHERS_DIR:-$HOME/.claude/.smithers}"
SMITHERS_BIN="./node_modules/.bin/smithers"
PIPELINE_WORKFLOW="workflows/se-pipeline.tsx"

usage() {
  cat <<'EOF'
Usage: se <command> [args]

Commands:
  pipeline <plan-path> [--until=branch|pr] [--validate-cmd '<cmd>'] [--attach]
      Launch the se-pipeline workflow for a plan file. Run from the target
      repository: the current directory becomes PIPELINE_REPO (and
      DOC_REVIEW_REPO for the verify-doc child workflow).
        --until          stop stage: branch (default) or pr
        --validate-cmd   Command the work gate runs to validate work in the run
                         worktree. OPTIONAL: if omitted, it is derived from the
                         plan's own Verification Contract (the scoped test/
                         typecheck commands the plan already declares). Pass this
                         only to override. Keep it FAST — it runs synchronously;
                         unit/type checks, NOT full e2e.
        --validate-timeout N   seconds before validate-cmd is killed (default
                         600). A too-broad command (e2e) that hits this fails
                         the gate — scope the command rather than raising this.
        --attach         run in the foreground streaming logs. NOTE: Ctrl-C
                         sends SIGINT, which CANCELS the run (smithers aborts
                         gracefully) — it does NOT detach. To leave a run going
                         and stop watching, launch without --attach (detached
                         is the default) and use `se logs <runId>` to follow.
                         Recover a cancelled run with `se resume <runId>`.
      Default is detached: prints the runId immediately and returns.
  list [--json]        list se-pipeline runs (status incl. waiting-approval)
                       --json: {runs, summaries} for unattended callers
  show <runId> [--json]
                       one run in depth: live status, summary verdict/branch,
                       report dir and its files. --json merges all of it
  logs <runId>         show logs for a run
  chat <runId>         open chat for a run
  approve <runId>      approve a paused run (continue past the gate)
  deny <runId>         deny a paused run (onDeny: fail)
  abort <runId>        hard-stop a run (smithers cancel)
  resume <runId>       resume a run (smithers up --run-id <id> --resume true)
  --help               show this help

Environment:
  SE_DRY_RUN=1         print the assembled command + env instead of executing
  SE_SMITHERS_DIR      override runtime dir (default: ~/.claude/.smithers)
EOF
}

die() {
  echo "se: $*" >&2
  exit 1
}

usage_die() {
  echo "se: $*" >&2
  usage >&2
  exit 1
}

dry_run() { [[ "${SE_DRY_RUN:-0}" == "1" ]]; }

sq() {
  local s=${1//\'/\'\\\'\'}
  printf "'%s'" "$s"
}

print_smithers_cmd() {
  printf 'cd %s &&' "$(sq "$SMITHERS_DIR")"
  local arg
  for arg in "$SMITHERS_BIN" "$@"; do
    if [[ $arg =~ ^[A-Za-z0-9_./:=-]+$ ]]; then
      printf ' %s' "$arg"
    else
      printf ' %s' "$(sq "$arg")"
    fi
  done
  printf '\n'
}

require_runtime_dir() {
  dry_run && return 0
  [[ -d "$SMITHERS_DIR" ]] || die "smithers runtime dir not found: $SMITHERS_DIR"
  [[ -x "$SMITHERS_DIR/$SMITHERS_BIN" ]] || die "smithers binary not found: $SMITHERS_DIR/$SMITHERS_BIN (run bun install in $SMITHERS_DIR)"
}

smithers_run() {
  if dry_run; then
    print_smithers_cmd "$@"
    return 0
  fi
  cd "$SMITHERS_DIR"
  "$SMITHERS_BIN" "$@"
}

json_escape() {
  local s=$1
  s=${s//\\/\\\\}
  s=${s//\"/\\\"}
  s=${s//$'\n'/\\n}
  s=${s//$'\r'/\\r}
  s=${s//$'\t'/\\t}
  printf '%s' "$s"
}

build_input_json() {
  local plan_path=$1 until=$2 validate_cmd=$3 validate_timeout_ms=$4
  if command -v jq >/dev/null 2>&1; then
    jq -cn --arg planPath "$plan_path" --arg until "$until" --arg validateCmd "$validate_cmd" \
      --argjson validateTimeoutMs "$validate_timeout_ms" \
      '{planPath: $planPath, until: $until, validateCmd: $validateCmd, validateTimeoutMs: $validateTimeoutMs}'
  else
    printf '{"planPath":"%s","until":"%s","validateCmd":"%s","validateTimeoutMs":%s}' \
      "$(json_escape "$plan_path")" "$(json_escape "$until")" "$(json_escape "$validate_cmd")" "$validate_timeout_ms"
  fi
}

cmd_pipeline() {
  local plan="" until="branch" validate_cmd="" attach=0 validate_timeout_s=600

  while (($#)); do
    case $1 in
      --until=*) until=${1#--until=} ;;
      --until)
        [[ $# -ge 2 ]] || usage_die "--until requires a value (branch|pr)"
        shift; until=$1 ;;
      --validate-cmd=*) validate_cmd=${1#--validate-cmd=} ;;
      --validate-cmd)
        [[ $# -ge 2 ]] || usage_die "--validate-cmd requires a value"
        shift; validate_cmd=$1 ;;
      --validate-timeout=*) validate_timeout_s=${1#--validate-timeout=} ;;
      --validate-timeout)
        [[ $# -ge 2 ]] || usage_die "--validate-timeout requires a value (seconds)"
        shift; validate_timeout_s=$1 ;;
      --attach) attach=1 ;;
      -h|--help) usage; return 0 ;;
      -*) usage_die "unknown option for pipeline: $1" ;;
      *)
        [[ -z $plan ]] || usage_die "unexpected argument: $1"
        plan=$1 ;;
    esac
    shift
  done

  [[ -n $plan ]] || usage_die "pipeline requires a <plan-path>"
  [[ -f $plan ]] || die "plan file not found: $plan"
  case $until in
    branch|pr) ;;
    *) usage_die "invalid --until value '$until' (must be branch|pr)" ;;
  esac
  # --validate-cmd is optional: when omitted, the workflow derives the command
  # from the plan's Verification Contract (gate-0). It hard-errors there if the
  # plan has none. An empty string in the input JSON signals "derive from plan".
  [[ $validate_timeout_s =~ ^[0-9]+$ ]] || usage_die "--validate-timeout must be an integer number of seconds"

  local plan_abs repo input
  plan_abs="$(cd "$(dirname "$plan")" && pwd -P)/$(basename "$plan")"
  repo="$(pwd -P)"
  input="$(build_input_json "$plan_abs" "$until" "$validate_cmd" "$((validate_timeout_s * 1000))")"

  local -a args=(up "$PIPELINE_WORKFLOW")
  ((attach)) || args+=(--detach)
  args+=(--input "$input")

  if dry_run; then
    printf 'PIPELINE_REPO=%s\n' "$repo"
    printf 'DOC_REVIEW_REPO=%s\n' "$repo"
    print_smithers_cmd "${args[@]}"
    return 0
  fi

  require_runtime_dir
  cd "$SMITHERS_DIR"
  local rc=0
  PIPELINE_REPO="$repo" DOC_REVIEW_REPO="$repo" "$SMITHERS_BIN" "${args[@]}" || rc=$?
  # exit 3 = run reached a durable wait (waiting-approval) — a pause, not a
  # failure. Only surfaces on --attach; --detach returns 0 immediately.
  if [[ $rc -eq 3 ]]; then
    echo "se: run paused at an Approval gate (awaiting a decision, not a failure). Use 'se list', then 'se approve|deny|abort <runId>'." >&2
    return 0
  fi
  return $rc
}

# jq filter: se-pipeline runs out of `smithers ps --format json` ({cta, runs}).
PS_RUNS_FILTER='[(.runs // .)[] | select((.workflowId // .workflow // "") == "se-pipeline")]'

cmd_list() {
  local as_json=0
  while (($#)); do
    case $1 in
      --json) as_json=1 ;;
      *) usage_die "unknown option for list: $1" ;;
    esac
    shift
  done
  require_runtime_dir
  if dry_run; then
    print_smithers_cmd ps --format json
    return 0
  fi
  cd "$SMITHERS_DIR"

  if ((as_json)); then
    command -v jq >/dev/null 2>&1 || die "se list --json requires jq"
    local runs summaries="[]"
    runs="$("$SMITHERS_BIN" ps --format json | jq "$PS_RUNS_FILTER")" || die "smithers ps failed"
    if command -v sqlite3 >/dev/null 2>&1 && [[ -f smithers.db ]]; then
      summaries="$(sqlite3 -json smithers.db \
        "SELECT verdict, run_id, branch, plan_path, report_dir, total_tokens, est_cost_usd
         FROM summary ORDER BY rowid DESC LIMIT 20")"
      [[ -n $summaries ]] || summaries="[]"
    fi
    jq -n --argjson runs "$runs" --argjson summaries "$summaries" \
      '{runs: $runs, summaries: $summaries}'
    return 0
  fi

  local out
  if command -v jq >/dev/null 2>&1; then
    # The toon-format `smithers ps` output interleaves runs with a giant
    # cta/description blob; render a compact table from the JSON instead.
    # Child runs (parentRunId set) are folded away — `se show` has them.
    out="$("$SMITHERS_BIN" ps --format json)" || die "smithers ps failed"
    echo "runs (id | status | started):"
    jq -r "$PS_RUNS_FILTER"' | .[] | select(.parentRunId == null)
      | [.id, .status, (.started // "")] | join(" | ")' <<<"$out"
  else
    out="$("$SMITHERS_BIN" ps)" || die "smithers ps failed"
    awk 'NR == 1 || /se-pipeline/' <<<"$out"
  fi

  # Cost per finished run comes ONLY from the run's summary output — the single
  # authoritative store (KTD6/U6); tokens are ground truth, USD is an estimate.
  if command -v sqlite3 >/dev/null 2>&1 && [[ -f smithers.db ]]; then
    echo
    echo "summary (verdict | run | branch | plan | tokens | ~USD):"
    local summary_out summary_rc
    summary_out="$(sqlite3 -separator ' | ' smithers.db \
      "SELECT s.verdict, substr(s.run_id, 1, 12), s.branch,
              replace(s.plan_path, rtrim(s.plan_path, replace(s.plan_path, '/', '')), ''),
              s.total_tokens, printf('%.2f', s.est_cost_usd)
       FROM summary s ORDER BY rowid DESC LIMIT 20" 2>&1)"
    summary_rc=$?
    # A real query error (locked db, missing table) must be distinguishable from
    # a genuinely empty history — never collapse both into "no summaries yet".
    if [[ $summary_rc -ne 0 ]]; then
      echo "  (summary query failed: $summary_out)" >&2
    elif [[ -z $summary_out ]]; then
      echo "  (no summaries yet — older runs predate the cost store)"
    else
      echo "$summary_out"
    fi
  fi
}

cmd_show() {
  local run_id="" as_json=0
  while (($#)); do
    case $1 in
      --json) as_json=1 ;;
      -*) usage_die "unknown option for show: $1" ;;
      *)
        [[ -z $run_id ]] || usage_die "unexpected argument: $1"
        run_id=$1 ;;
    esac
    shift
  done
  [[ -n $run_id ]] || usage_die "show requires a <runId>"
  # run_id lands in a SQL literal below — allow only smithers id charset.
  [[ $run_id =~ ^[A-Za-z0-9:_-]+$ ]] || die "invalid runId: $run_id"
  require_runtime_dir
  if dry_run; then
    print_smithers_cmd inspect "$run_id" --format json
    return 0
  fi
  cd "$SMITHERS_DIR"
  command -v jq >/dev/null 2>&1 || die "se show requires jq"

  # Child run ids (…:child:…) are rejected by `smithers inspect` — the summary
  # row and report dir still resolve, so inspect degrades to null, not a die.
  local inspect summary="[]"
  inspect="$("$SMITHERS_BIN" inspect "$run_id" --format json 2>/dev/null)" || inspect="null"
  if command -v sqlite3 >/dev/null 2>&1 && [[ -f smithers.db ]]; then
    summary="$(sqlite3 -json smithers.db \
      "SELECT verdict, run_id, branch, plan_path, report_dir, total_tokens, est_cost_usd, notes
       FROM summary WHERE run_id='$run_id' LIMIT 1")"
    [[ -n $summary ]] || summary="[]"
  fi

  local report_dir files="[]"
  report_dir="$(jq -r '.[0].report_dir // empty' <<<"$summary")"
  if [[ -n $report_dir && -d $report_dir ]]; then
    files="$(find "$report_dir" -maxdepth 1 -type f -exec basename {} \; | jq -R . | jq -s 'sort')"
  fi

  if ((as_json)); then
    jq -n --argjson run "${inspect:-null}" --argjson summary "$summary" \
      --argjson reportFiles "$files" --arg reportDir "${report_dir:-}" \
      '{run: ($run.run? // $run), summary: ($summary[0] // null),
        reportDir: (if $reportDir == "" then null else $reportDir end),
        reportFiles: $reportFiles}'
    return 0
  fi

  jq -rn --argjson run "${inspect:-null}" --argjson summary "$summary" \
    --argjson reportFiles "$files" --arg reportDir "${report_dir:-}" --arg id "$run_id" '
    def row(k; v): "\(k): \(if v == null or v == "" then "—" else v end)";
    row("run"; $id),
    row("status"; ($run.run.status? // $run.status? // null)),
    row("verdict"; ($summary[0].verdict? // null)),
    row("branch"; ($summary[0].branch? // null)),
    row("plan"; ($summary[0].plan_path? // null)),
    row("tokens"; ($summary[0].total_tokens? | if . == null then null else (round | tostring) end)),
    row("~USD"; ($summary[0].est_cost_usd? | if . == null then null else (. * 100 | round / 100 | tostring) end)),
    row("reportDir"; (if $reportDir == "" then null else $reportDir end)),
    ("reportFiles: " + ($reportFiles | join(", ") | if . == "" then "—" else . end)),
    row("notes"; ($summary[0].notes? // null))'
}

cmd_resume() {
  local run_id=$1
  require_runtime_dir
  if dry_run; then
    print_smithers_cmd up "$PIPELINE_WORKFLOW" --run-id "$run_id" --resume true
    return 0
  fi
  cd "$SMITHERS_DIR"

  # The workflow reads the target repo from PIPELINE_REPO/DOC_REVIEW_REPO at
  # module load; resume must restore them or the resumed run would target the
  # smithers dir (cwd) instead of the original repo. The repo is persisted in
  # the run's gate0 output, so recover it from smithers.db.
  local repo=""
  if command -v sqlite3 >/dev/null 2>&1 && [[ -f smithers.db ]]; then
    repo="$(sqlite3 smithers.db "SELECT repo_path FROM gate0 WHERE run_id='$run_id' LIMIT 1" 2>/dev/null || true)"
  fi
  if [[ -z $repo ]]; then
    die "cannot resume $run_id: no persisted repo path found (gate0 not reached, or pre-U6 run). Re-launch with 'se pipeline' from the target repo."
  fi

  local rc=0
  PIPELINE_REPO="$repo" DOC_REVIEW_REPO="$repo" "$SMITHERS_BIN" up "$PIPELINE_WORKFLOW" --run-id "$run_id" --resume true || rc=$?
  # exit 3 = the resumed run advanced and paused again at an Approval gate — a
  # normal outcome, NOT a resume failure. Anything else is a real failure.
  if [[ $rc -eq 3 ]]; then
    echo "se: resumed; run is paused at an Approval gate (awaiting a decision). Use 'se list', then 'se approve|deny|abort $run_id'." >&2
    return 0
  fi
  if [[ $rc -ne 0 ]]; then
    {
      echo "se: resume failed for $run_id (exit $rc)"
      echo "se: hint: force-resuming a killed run needs '--force true', and smithers refuses while the dead owner's heartbeat is still fresh (~30-45s) — wait and retry."
      echo "se: suggested command from 'smithers why $run_id':"
      "$SMITHERS_BIN" why "$run_id" || true
    } >&2
    exit 1
  fi
}

require_run_id() {
  local cmd=$1
  [[ $# -ge 2 && -n ${2:-} ]] || usage_die "$cmd requires a <runId>"
}

main() {
  (($#)) || { usage >&2; exit 1; }
  local cmd=$1
  shift
  case $cmd in
    -h|--help|help) usage ;;
    pipeline) cmd_pipeline "$@" ;;
    list) cmd_list "$@" ;;
    show) cmd_show "$@" ;;
    logs|chat|approve|deny)
      require_run_id "$cmd" "$@"
      require_runtime_dir
      smithers_run "$cmd" "$@" ;;
    abort)
      require_run_id abort "$@"
      require_runtime_dir
      smithers_run cancel "$@" ;;
    resume)
      require_run_id resume "$@"
      cmd_resume "$@" ;;
    *) usage_die "unknown command: $cmd" ;;
  esac
}

main "$@"
